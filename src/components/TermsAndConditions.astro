---
import { content } from '../content/privacy-content';
---
<section class="max-w-5xl mx-auto py-20 px-6 md:px-16 mt-16 reveal" data-section="terms">
  <div class="theme-card p-6 md:p-10 relative overflow-hidden">
    <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -left-20 -bottom-20 w-64 h-64 bg-red-500/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="flex flex-col gap-3 border-b border-border-theme/40 pb-6 mb-8 relative z-10">
      <h3 class="text-2xl md:text-3xl font-bold font-display tracking-tight">
        {content.terms.title}
      </h3>
      <p class="font-medium opacity-60 text-base md:text-lg max-w-2xl">Por favor lee detenidamente los siguientes términos antes de seguir navegando. Al usar este sitio, aceptas todo esto sin chistar:</p>
    </div>

    <div class="relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6 stagger">
        {content.terms.list.map((term, i) => (
          <div class="flex gap-3 items-start group">
            <div class="w-7 h-7 rounded-lg bg-bg-base border border-border-theme flex items-center justify-center shrink-0 text-xs font-bold opacity-50 group-hover:opacity-100 group-hover:border-primary group-hover:text-primary transition-all mt-0.5">
              {i + 1}
            </div>
            <p class="leading-relaxed opacity-75 group-hover:opacity-100 transition-opacity text-sm md:text-base" set:html={term}></p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-5 p-5 border-2 border-red-500/20 bg-red-500/5 rounded-xl relative z-10">
      <div class="flex items-center gap-3 w-full sm:w-auto">
        <input type="checkbox" id="fake-checkbox" class="w-5 h-5 accent-red-500 cursor-not-allowed shrink-0 animate-pulse" checked disabled />
        <label for="fake-checkbox" class="text-sm md:text-base font-bold text-red-600 dark:text-red-400">He leído y acepto los términos y condiciones absurdos.</label>
      </div>
      <span class="text-xs font-mono uppercase tracking-widest opacity-40 shrink-0">Contrato Autoejecutable</span>
    </div>
  </div>
</section>
