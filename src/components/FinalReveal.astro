---
import { content } from '../content/privacy-content';
import { ExternalLink, Shield, BookOpen, Scale, Landmark } from '@lucide/astro';

const resourceIcons = ['shield', 'external', 'book', 'scale', 'landmark'];
---
<section class="py-28 md:py-36 px-6 md:px-16 max-w-5xl mx-auto text-center flex flex-col gap-10 items-center mt-24 relative reveal">
  <!-- Curtain line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-0 h-px bg-primary animate-curtain-expand"></div>
  <div class="absolute inset-0 bg-linear-to-b from-transparent via-primary/5 to-transparent -z-10 blur-3xl"></div>

  <h2 class="text-4xl md:text-6xl lg:text-7xl font-display font-black text-primary tracking-tighter leading-tight">
    {content.reveal.title}
  </h2>

  <div class="max-w-3xl space-y-6 text-lg md:text-xl leading-relaxed mt-2">
    <p class="font-medium opacity-85">{content.reveal.description1}</p>
    <p class="font-bold text-xl md:text-2xl">{content.reveal.description2}</p>
  </div>

  <blockquote class="text-2xl md:text-3xl lg:text-4xl font-display font-medium italic opacity-90 border-l-[6px] pl-6 md:pl-8 border-primary text-left my-8 max-w-4xl leading-snug">
    &ldquo;{content.reveal.quote}&rdquo;
  </blockquote>

  <div class="w-full max-w-5xl mt-6 text-left stagger">
    <h3 class="text-xl md:text-2xl font-display font-bold mb-6 text-center opacity-80">{content.reveal.resourcesTitle}</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
      {content.reveal.resources.map((resource, i) => (
        <a href={resource.href} target="_blank" rel="noopener noreferrer" data-track="external_resource_click" data-track-label={resource.label} class="theme-card p-5 md:p-6 text-left group block h-full transition-all duration-200 hover:-translate-y-1 active:scale-[0.98]">
          <div class="flex items-center gap-3 mb-3">
            {i === 0 && <Shield class="text-primary w-5 h-5 shrink-0" stroke-width="2" />}
            {i === 1 && <ExternalLink class="text-primary w-5 h-5 shrink-0" stroke-width="2" />}
            {i === 2 && <BookOpen class="text-primary w-5 h-5 shrink-0" stroke-width="2" />}
            {i === 3 && <Scale class="text-primary w-5 h-5 shrink-0" stroke-width="2" />}
            {i === 4 && <Landmark class="text-primary w-5 h-5 shrink-0" stroke-width="2" />}
            <p class="text-lg font-bold font-display text-primary group-hover:underline underline-offset-4">{resource.label}</p>
          </div>
          <p class="text-base leading-relaxed opacity-80">{resource.description}</p>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-8 w-full sm:w-auto">
    <a href="https://myshadow.org/es" target="_blank" rel="noopener noreferrer" data-track="final_cta_click" data-track-label={content.reveal.cta} class="theme-btn py-5 px-10 inline-flex text-lg active:scale-[0.97]">
      {content.reveal.cta}
    </a>
  </div>
</section>

<style>
  @keyframes curtain-expand {
    0% { width: 0; }
    100% { width: 80%; }
  }
  .animate-curtain-expand {
    animation: curtain-expand 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.3s;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-curtain-expand { animation: none; width: 80%; }
  }
</style>
